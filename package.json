{
  "name": "tonesmith",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "clean": "find core cli mcp -name dist -type d -o -name '*.tsbuildinfo' | xargs rm -rf",
    "html-to-md": "tsx tools/html-to-md/index.ts",
    "html-to-md:gx1": "tsx tools/html-to-md/index.ts tools/html-to-md/gx1.json",
    "lint": "eslint core cli mcp tools",
    "lint:fix": "eslint core cli mcp tools --fix"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "eslint": "10.5.0",
    "node-html-parser": "8.0.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
